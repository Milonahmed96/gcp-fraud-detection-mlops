<?xml version="1.0" encoding="UTF-8"?>
<!--
  GCP MLOps Pipeline — Real-Time Fraud Detection on Vertex AI
  Editable architecture diagram. Open at https://app.diagrams.net
  (File > Open from > Device), or in the VS Code Draw.io Integration extension.

  Convention: SOLID edges are implemented and tested. DASHED edges are designed
  but not wired — they mirror the "Known limitations" section of the README.
-->
<mxfile host="app.diagrams.net" version="24.0.0" type="device">
  <diagram id="fraud-mlops-architecture" name="Architecture">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1"
                  connect="1" arrows="1" fold="1" page="1" pageScale="1"
                  pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ============================ Swimlanes ============================ -->
        <mxCell id="lane-ingest" value="Data &amp; Features"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f9ff;strokeColor=#2a78d6;dashed=0;verticalAlign=top;fontStyle=1;fontSize=13;arcSize=6;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="280" height="360" as="geometry" />
        </mxCell>

        <mxCell id="lane-train" value="Training — src/training"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4fbf8;strokeColor=#1baf7a;verticalAlign=top;fontStyle=1;fontSize=13;arcSize=6;"
          vertex="1" parent="1">
          <mxGeometry x="380" y="60" width="280" height="240" as="geometry" />
        </mxCell>

        <mxCell id="lane-serve" value="Serving — Cloud Run (inference image)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f9ff;strokeColor=#2a78d6;verticalAlign=top;fontStyle=1;fontSize=13;arcSize=6;"
          vertex="1" parent="1">
          <mxGeometry x="720" y="60" width="320" height="280" as="geometry" />
        </mxCell>

        <mxCell id="lane-ops" value="Monitoring — Cloud Run (monitoring image)"
