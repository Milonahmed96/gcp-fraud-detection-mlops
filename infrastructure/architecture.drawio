          vertex="1" parent="1">
          <mxGeometry x="720" y="400" width="320" height="300" as="geometry" />
        </mxCell>

        <mxCell id="lane-cicd" value="CI/CD"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f7f6fc;strokeColor=#4a3aa7;verticalAlign=top;fontStyle=1;fontSize=13;arcSize=6;"
          vertex="1" parent="1">
          <mxGeometry x="380" y="560" width="280" height="140" as="geometry" />
        </mxCell>

        <!-- ============================ Ingest ============================ -->
        <mxCell id="src" value="Transaction source&#10;(payment gateway)"
