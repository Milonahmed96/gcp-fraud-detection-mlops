          vertex="1" parent="1">
          <mxGeometry x="80" y="285" width="200" height="55" as="geometry" />
        </mxCell>

        <mxCell id="plog" value="BigQuery prediction_log&#10;schema exists, writer exists,&#10;serving path does not call it"
